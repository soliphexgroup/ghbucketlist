# Paystack API keys — get these from https://dashboard.paystack.com/#/settings/developer
# Use TEST keys (sk_test_... / pk_test_...) for development. Never commit real keys.

# Server-only — used by src/app/api/paystack/verify to confirm transactions. Never expose to the client.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Safe to expose in the browser — used to open the Paystack Inline checkout popup.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
